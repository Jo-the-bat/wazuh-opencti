# ==========================================
# Wazuh + OpenCTI Configuration
# ==========================================
# Copy this to .env and customize, or just run: bash setup.sh
# setup.sh generates all passwords, tokens, and UUIDs automatically.

# --- Wazuh ---
WAZUH_VERSION=4.14.4
WAZUH_CERTS_GENERATOR_VERSION=0.0.2
WAZUH_INDEXER_PASSWORD=       # auto-generated by setup.sh
WAZUH_API_PASSWORD=           # auto-generated by setup.sh
WAZUH_DASHBOARD_PASSWORD=     # auto-generated by setup.sh

# --- OpenCTI ---
OPENCTI_VERSION=6.9.28
OPENCTI_BASE_URL=https://localhost:8443
OPENCTI_ADMIN_EMAIL=admin@opencti.io
OPENCTI_ADMIN_PASSWORD=       # auto-generated by setup.sh
OPENCTI_ADMIN_TOKEN=          # auto-generated by setup.sh (UUID)
OPENCTI_PORT=8443
OPENCTI_HEALTH_KEY=           # auto-generated by setup.sh

# --- Elasticsearch (for OpenCTI) ---
ELASTICSEARCH_VERSION=8.19.13
ELASTIC_MEMORY_SIZE=3G
ELASTIC_PASSWORD=             # auto-generated by setup.sh

# --- Redis ---
REDIS_VERSION=7.4
REDIS_PASSWORD=               # auto-generated by setup.sh

# --- RabbitMQ ---
RABBITMQ_VERSION=4.2.5-management
RABBITMQ_DEFAULT_USER=opencti
RABBITMQ_DEFAULT_PASS=        # auto-generated by setup.sh

# --- MinIO ---
MINIO_VERSION=RELEASE.2025-09-07T16-13-09Z
MINIO_ROOT_USER=opencti
MINIO_ROOT_PASSWORD=          # auto-generated by setup.sh

# --- Internal Connector IDs (auto-generated UUIDs) ---
CONNECTOR_EXPORT_FILE_STIX_ID=
CONNECTOR_EXPORT_FILE_CSV_ID=
CONNECTOR_IMPORT_FILE_STIX_ID=
CONNECTOR_IMPORT_DOCUMENT_ID=

# --- Threat Intel Connector IDs (auto-generated UUIDs) ---
CONNECTOR_MITRE_ID=
CONNECTOR_OPENCTI_DATASETS_ID=
CONNECTOR_URLHAUS_ID=
CONNECTOR_CISA_KEV_ID=
CONNECTOR_THREATFOX_ID=
CONNECTOR_VXVAULT_ID=
CONNECTOR_DISARM_ID=

# --- Wazuh-OpenCTI Integration ---
WAZUH_CONNECTOR_VERSION=0.3.0
CONNECTOR_WAZUH_ID=

# --- Optional: API-Key Connectors ---
# Uncomment and fill to enable. Start with:
#   docker compose --profile alienvault --profile abuseipdb --profile cve up -d
#ALIENVAULT_API_KEY=your-otx-api-key
#CONNECTOR_ALIENVAULT_ID=
#ABUSEIPDB_API_KEY=your-abuseipdb-key
#CONNECTOR_ABUSEIPDB_ID=
#CVE_API_KEY=your-nist-nvd-key
#CONNECTOR_CVE_ID=

# --- Shuffle SOAR ---
SHUFFLE_VERSION=v2.2.0
SHUFFLE_OPENSEARCH_VERSION=2.14.0
SHUFFLE_DEFAULT_USERNAME=admin
SHUFFLE_DEFAULT_PASSWORD=     # auto-generated by setup.sh
SHUFFLE_DEFAULT_APIKEY=       # auto-generated by setup.sh (UUID)
SHUFFLE_ENCRYPTION_MODIFIER=  # auto-generated by setup.sh
SHUFFLE_PORT=3443

# --- Monitoring (optional) ---
# Activate with: docker compose --profile monitoring up -d
PROMETHEUS_VERSION=v3.11.0
CADVISOR_VERSION=v0.56.2
GRAFANA_VERSION=12.4.2
GRAFANA_ADMIN_PASSWORD=       # auto-generated by setup.sh

# --- SMTP (optional) ---
SMTP_HOSTNAME=localhost       # Change to real SMTP server for email alerts

# --- Nginx hostname (used for self-signed cert CN and SAN) ---
OPENCTI_HOSTNAME=localhost    # Change for production (e.g., soc.example.com)
