# Web proxy configuration
# Copy this file to proxy.env and set your proxy URLs.
# Both upper and lowercase variants are set for maximum compatibility.
#
# Example:
#   HTTP_PROXY=http://proxy.corp.example.com:8080
#   HTTPS_PROXY=http://proxy.corp.example.com:8080
#
# NO_PROXY already includes internal service hostnames.
# Append any additional hosts your environment needs.

HTTP_PROXY=
HTTPS_PROXY=
http_proxy=${HTTP_PROXY}
https_proxy=${HTTPS_PROXY}
NO_PROXY=localhost,127.0.0.1,opencti,elasticsearch,redis,rabbitmq,minio,wazuh.manager,wazuh.indexer,wazuh.dashboard,nginx
no_proxy=${NO_PROXY}
